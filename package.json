{
  "name": "tuzzle-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm --recursive run build",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --recursive run test",
    "check-exports": "pnpm --recursive --filter=./packages/* exec publint",
    "clean": "pnpm --recursive run clean && tsc --build --clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.30.0",
    "@types/node": "^26.1.1",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.0",
    "publint": "^0.3.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.35.0"
  }
}
