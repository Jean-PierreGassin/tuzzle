{
  "name": "tuzzle",
  "version": "0.1.0",
  "description": "A 1:1 TypeScript port of Guzzle, the PHP HTTP client. See https://docs.guzzlephp.org/ for fidelity reference.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "test": "tsx --test src/**/*.test.ts",
    "clean": "rimraf dist .tsbuild"
  },
  "dependencies": {
    "@tuzzle/message": "workspace:*",
    "@tuzzle/promises": "workspace:*"
  }
}
