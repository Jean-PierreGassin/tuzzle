{
  "name": "@tuzzle/promises",
  "version": "0.1.0",
  "description": "Promise aggregation utilities for tuzzle — the TypeScript equivalent of guzzlehttp/promises.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "test": "tsx --test src/**/*.test.ts",
    "clean": "rimraf dist .tsbuild"
  }
}
